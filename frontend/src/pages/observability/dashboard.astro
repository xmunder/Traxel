---
import ObsDashboard from '../../components/ObsDashboard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/observability.css';

const obsEndpoint = import.meta.env.PUBLIC_OBS_ENDPOINT ?? 'http://127.0.0.1:8000';
---

<BaseLayout
	title="Traxel — Observability Dashboard"
	pathname="/observability/dashboard"
	robots="noindex, nofollow"
	bodyClass="obs-body"
	fonts="inter"
>
	<main id="main-content">
		<div
			data-obs-dashboard
			data-endpoint={obsEndpoint}
		>
			<ObsDashboard />
		</div>
	</main>

	<script>
		import { initObsDashboard } from '../../lib/obs-dashboard';

		initObsDashboard();
	</script>
</BaseLayout>
