---
import UploadZone from '../components/UploadZone.astro';
import '../styles/vectorizer.css';

const vectorizeEndpoint = import.meta.env.PUBLIC_VECTORIZE_ENDPOINT ?? 'http://127.0.0.1:8000/vectorize';

const capabilities = [
	{
		icon: 'auto_fix_high',
		title: 'Smart Tracing',
		copy: 'Automatic edge detection with sub-pixel precision.',
	},
	{
		icon: 'palette',
		title: 'Color Palette Extraction',
		copy: 'Auto-generate vector layers based on visual depth.',
	},
	{
		icon: 'layers',
		title: 'Multi-Layer SVGs',
		copy: 'Perfectly organized groups for easy editing.',
	},
];
---

<html class="dark" lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
		<title>Vectorizer | System Active</title>
	</head>
	<body class="mvp-upload-body">
		<div
			class="mvp-upload-page"
			data-vectorizer-app
			data-page="upload"
			data-endpoint={vectorizeEndpoint}
			data-workspace-path="/workspace"
			data-state="idle"
		>
			<header class="mvp-upload-header">
				<div class="mvp-upload-header__brand">Vectorizer</div>
				<div class="mvp-upload-header__actions">
					<button type="button" class="mvp-upload-header__icon" aria-label="Help center">
						<span class="material-symbols-outlined">help_outline</span>
					</button>
					<button type="button" class="mvp-upload-header__icon" aria-label="Settings">
						<span class="material-symbols-outlined">settings</span>
					</button>
				</div>
			</header>

			<main class="mvp-upload-main">
				<div class="mvp-upload-main__glow mvp-upload-main__glow--left" aria-hidden="true"></div>
				<div class="mvp-upload-main__glow mvp-upload-main__glow--right" aria-hidden="true"></div>

				<div class="mvp-upload-shell">
					<section class="mvp-upload-hero">
						<h1>
							Convert Pixels <br />
							<span>into Precision Paths</span>
						</h1>
						<p>
							The industry's most advanced SVG engine. Upload your raster assets and receive clean,
							production-ready vector architecture.
						</p>
					</section>

					<section class="mvp-upload-layout" aria-label="Upload and capability overview">
						<div class="mvp-upload-layout__left">
							<UploadZone />
						</div>

						<aside class="mvp-upload-layout__right">
							<div class="mvp-upload-warning" data-warning aria-live="polite">
								<span class="material-symbols-outlined">warning</span>
								<p>Optimized for logos &amp; icons. Complex images or photos may need manual cleanup.</p>
							</div>

							<div class="mvp-upload-formats">
								<span>Supported Formats</span>
								<div class="mvp-upload-formats__chips">
									<span>PNG</span>
									<span>JPG</span>
									<span>WEBP</span>
								</div>
							</div>

							<div class="mvp-upload-capabilities">
								{capabilities.map((item) => (
									<article class="mvp-upload-capability">
										<div class="mvp-upload-capability__icon">
											<span class="material-symbols-outlined">{item.icon}</span>
										</div>
										<div>
											<h3>{item.title}</h3>
											<p>{item.copy}</p>
										</div>
									</article>
								))}
							</div>

							<div class="mvp-upload-runtime-panel">
								<div class="mvp-upload-runtime-panel__item">
									<span>Selected file</span>
									<strong data-selected-file>Ningún archivo seleccionado.</strong>
								</div>
								<div class="mvp-upload-runtime-panel__item">
									<span>Status</span>
									<strong data-state-label>Ready</strong>
								</div>
							</div>
						</aside>
					</section>
				</div>
			</main>

			<footer class="mvp-upload-footer">
				<div class="mvp-upload-footer__group">
					<span>Vectorizer v0.1.0-beta</span>
					<span>Engine: Vectorizer Contour Engine</span>
				</div>
				<div class="mvp-upload-footer__group">
					<span class="mvp-upload-footer__indicator"><i></i>Cloud Services Active</span>
					<span data-state-footer>State: Ready</span>
				</div>
			</footer>
		</div>

		<script>
			import { initVectorizerApp } from '../lib/vectorizer-app';

			initVectorizerApp();
		</script>
	</body>
</html>
