---
import Preview from '../components/Preview.astro';
import UploadZone from '../components/UploadZone.astro';

const vectorizeEndpoint = import.meta.env.PUBLIC_VECTORIZE_ENDPOINT ?? 'http://127.0.0.1:8000/vectorize';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Vectorizador de imagen a SVG</title>
	</head>
	<body>
		<main class="shell" data-vectorizer-app data-endpoint={vectorizeEndpoint}>
			<UploadZone />

			<aside class="warning" aria-live="polite">
				<strong>Importante:</strong> esta herramienta está optimizada para logos e íconos.
				En imágenes complejas o fotografías el resultado puede no quedar ideal, pero el flujo
				no se bloquea.
			</aside>

			<Preview />
		</main>

		<script>
			import { initVectorizerApp } from '../lib/vectorizer-app';

			initVectorizerApp();
		</script>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		background: #f3f4f6;
		color: #111827;
	}

	body {
		margin: 0;
		background:
			radial-gradient(circle at top, rgba(191, 219, 254, 0.55), transparent 28%),
			#f3f4f6;
	}

	.shell {
		max-width: 1120px;
		margin: 0 auto;
		padding: 2rem 1rem 3rem;
		display: grid;
		gap: 1rem;
	}

	.panel {
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid #dbe1ea;
		border-radius: 20px;
		padding: 1.5rem;
		box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
	}

	.section-copy h1,
	.preview-panel h2,
	.preview-card h3 {
		margin: 0;
	}

	.section-copy p,
	.muted {
		margin: 0.5rem 0 0;
		color: #4b5563;
		line-height: 1.6;
	}

	.upload-form {
		margin-top: 1.5rem;
		display: grid;
		gap: 0.875rem;
	}

	.upload-zone {
		border: 2px dashed #93c5fd;
		border-radius: 18px;
		padding: 2rem 1.25rem;
		display: grid;
		gap: 0.5rem;
		text-align: center;
		background: #eff6ff;
		cursor: pointer;
		transition:
			border-color 160ms ease,
			transform 160ms ease,
			background 160ms ease,
			box-shadow 160ms ease;
	}

	.upload-zone:hover,
	.upload-zone:focus-visible,
	.upload-zone[data-dragging='true'] {
		background: #dbeafe;
		border-color: #2563eb;
		transform: translateY(-1px);
		box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
		outline: none;
	}

	.upload-zone[aria-busy='true'] {
		cursor: progress;
		opacity: 0.72;
	}

	.upload-zone__title {
		font-size: 1.15rem;
		font-weight: 700;
	}

	.upload-zone__copy,
	.upload-zone__file,
	.status,
	.error {
		font-size: 0.975rem;
	}

	.upload-zone__file {
		color: #1d4ed8;
		font-weight: 600;
	}

	.status {
		padding: 0.75rem 0.875rem;
		border-radius: 14px;
		background: #eff6ff;
		color: #1e3a8a;
	}

	.error {
		padding: 0.75rem 0.875rem;
		border-radius: 14px;
		background: #fef2f2;
		color: #b91c1c;
		border: 1px solid #fecaca;
	}

	.warning {
		padding: 1rem 1.25rem;
		border-radius: 18px;
		background: #fff7ed;
		border: 1px solid #fdba74;
		color: #9a3412;
		line-height: 1.6;
	}

	.preview-panel {
		display: grid;
		gap: 1rem;
	}

	.preview-panel__header,
	.preview-actions {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: center;
		flex-wrap: wrap;
	}

	.zoom-controls {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.zoom-controls__label {
		min-width: 3rem;
		text-align: center;
		font-weight: 600;
	}

	.secondary-button,
	.primary-link {
		border-radius: 999px;
		border: 1px solid #cbd5e1;
		padding: 0.7rem 1rem;
		font: inherit;
		font-weight: 600;
		background: #ffffff;
		color: #0f172a;
		text-decoration: none;
		cursor: pointer;
	}

	.secondary-button:disabled,
	.primary-link[aria-disabled='true'] {
		opacity: 0.45;
		cursor: not-allowed;
		pointer-events: none;
	}

	.primary-link {
		background: #2563eb;
		border-color: #2563eb;
		color: #ffffff;
	}

	.metadata-list {
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 0.75rem;
	}

	.metadata-list div {
		padding: 1rem;
		border-radius: 16px;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
	}

	.metadata-list dt {
		color: #475569;
		font-size: 0.9rem;
	}

	.metadata-list dd {
		margin: 0.35rem 0 0;
		font-size: 1.35rem;
		font-weight: 700;
	}

	.preview-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.preview-card {
		display: grid;
		gap: 0.75rem;
	}

	.preview-frame {
		min-height: 280px;
		padding: 1rem;
		border-radius: 18px;
		border: 1px solid #dbe1ea;
		background:
			linear-gradient(45deg, #f8fafc 25%, transparent 25%),
			linear-gradient(-45deg, #f8fafc 25%, transparent 25%),
			linear-gradient(45deg, transparent 75%, #f8fafc 75%),
			linear-gradient(-45deg, transparent 75%, #f8fafc 75%);
		background-size: 22px 22px;
		background-position:
			0 0,
			0 11px,
			11px -11px,
			-11px 0;
		overflow: auto;
	}

	.preview-canvas {
		min-width: fit-content;
		transform: scale(var(--preview-scale, 1));
		transform-origin: top left;
	}

	.preview-canvas img,
	.preview-canvas svg,
	.preview-canvas [data-svg-container] {
		display: block;
		max-width: 100%;
	}

	.preview-canvas img,
	.preview-canvas svg {
		max-height: 520px;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 900px) {
		.preview-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.shell {
			padding-inline: 0.75rem;
		}

		.panel {
			padding: 1.125rem;
		}

		.upload-zone {
			padding: 1.5rem 1rem;
		}
	}
</style>
