---
import Preview from '../components/Preview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/vectorizer.css';
---

<BaseLayout
	title="Traxel — Comparison Workspace"
	pathname="/workspace"
	robots="noindex, nofollow"
	bodyClass="workspace-review-body"
>
	<div class="workspace-review-page" data-vectorizer-app data-page="workspace" data-home-path="/" data-state="idle">
		<header class="workspace-review-header">
			<div class="workspace-review-header__brand">
				<img class="app-brand-mark" src="/screen.png" alt="Traxel logo" width="28" height="28" />
				<strong>Traxel</strong>
				<span>Comparison Workspace</span>
			</div>
			<a class="workspace-review-header__action" href="/">New Upload</a>
		</header>

		<main class="workspace-review-main" id="main-content">
			<Preview />
		</main>
	</div>

	<script>
		import { initVectorizerApp } from '../lib/vectorizer-app';

		initVectorizerApp();
	</script>
</BaseLayout>
