<section class="workspace-review-shell" aria-label="Comparison workspace">
	<section class="workspace-review-ready" data-workspace-ready hidden>
		<div class="workspace-review-stage">
			<article class="workspace-review-panel workspace-review-panel--original">
				<div class="workspace-review-panel__header">
					<span>Original Image</span>
					<small data-workspace-filename>JPEG • SESSION</small>
				</div>
				<div class="workspace-review-panel__canvas">
					<img data-original-image alt="Original raster image uploaded by the user" />
				</div>
			</article>

			<article class="workspace-review-panel workspace-review-panel--generated">
				<div class="workspace-review-panel__header workspace-review-panel__header--generated">
					<span>Generated SVG</span>
					<div class="workspace-review-panel__pills">
						<strong>Vector</strong>
					</div>
				</div>
				<div class="workspace-review-panel__canvas workspace-review-panel__canvas--vector">
					<div data-svg-container aria-label="Generated SVG output"></div>
				</div>
			</article>
		</div>

		<div class="workspace-review-toolbar">
			<div class="workspace-review-toolbar__metrics">
				<div class="workspace-review-metric">
					<span>Colors</span>
					<strong data-metadata-colors>—</strong>
				</div>
				<div class="workspace-review-metric">
					<span>Paths</span>
					<strong data-metadata-paths>—</strong>
				</div>
				<div class="workspace-review-metric">
					<span>Time</span>
					<strong data-metadata-duration>—</strong>
				</div>
			</div>

			<div class="workspace-review-toolbar__actions">
				<a class="workspace-review-header__action" data-download-link href="#" download="vectorized.svg" aria-disabled="true">
					Download SVG
				</a>
			</div>
		</div>

		<div hidden aria-hidden="true">
			<span data-metadata-bezier>—</span>
			<span data-trace-quality>ULTRA</span>
			<span data-accuracy-index>98.4%</span>
			<span data-system-status>OPERATIONAL</span>
			<strong data-state-footer>STATE: READY</strong>
			<ul data-log-list></ul>
		</div>
	</section>
</section>
