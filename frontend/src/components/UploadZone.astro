<section class="mvp-upload-card" aria-labelledby="upload-title">
	<form class="mvp-upload-card__frame" data-upload-form novalidate>
		<input
			id="image-input"
			class="sr-only"
			data-image-input
			type="file"
			name="image"
			accept=".png,.jpg,.jpeg,.webp,image/png,image/jpeg,image/webp"
		/>

		<div class="mvp-upload-card__dropzone" data-dropzone aria-describedby="upload-support upload-status upload-error">
			<div class="mvp-upload-card__icon">
				<span class="material-symbols-outlined">cloud_upload</span>
			</div>

			<div class="mvp-upload-card__copy">
				<h2 id="upload-title">Drag your artwork here</h2>
				<p class="mvp-upload-card__microcopy">or select a local file</p>
			</div>

			<button type="button" class="mvp-upload-card__button" data-upload-trigger>
				Upload Image
			</button>

			<div class="mvp-upload-card__warning">
				<span class="material-symbols-outlined">warning</span>
				<span>Maximum file size: 5MB</span>
			</div>

			<p class="mvp-upload-card__statecopy" data-state-copy>Manual uplink ready</p>
			<p class="status-line" id="upload-status" data-status aria-live="polite"></p>
			<p class="error-line" id="upload-error" data-error aria-live="assertive" hidden></p>
		</div>
	</form>
</section>
