SERVICE_NAME=vectorizer-backend
SERVICE_VERSION=0.1.0
DEPLOYMENT_ENVIRONMENT=development
LOG_LEVEL=INFO

OBS_USERNAME=
OBS_SECRET=
OBS_DB_PATH=data/obs.db
OBS_RETENTION_DAYS=30
OBS_FLUSH_INTERVAL_S=1.0
OBS_FLUSH_BATCH_SIZE=100

# Comma-separated list, e.g. http://localhost:4321,http://127.0.0.1:4321
CORS_ALLOW_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,http://localhost:4411,http://127.0.0.1:4411
